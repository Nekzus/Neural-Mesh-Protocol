{
	"name": "@neural-mesh/sdk",
	"version": "1.0.0-alpha.1",
	"description": "SDK oficial para Neural Mesh Protocol (NMP). Despliega Logic-on-Origin con WebAssembly a velocidad gRPC y compatibilidad MCP bidireccional.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:all": "vitest run",
		"test:integration": "vitest run tests/integration",
		"test:conformance": "vitest run tests/conformance",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check .",
		"demo:client-quickstart": "pnpm --filter @neural-mesh/example-client-quickstart start",
		"demo:server-quickstart": "pnpm --filter @neural-mesh/example-server-quickstart start",
		"demo:server": "pnpm --filter @neural-mesh/example-server start",
		"demo:client": "pnpm --filter @neural-mesh/example-client start"
	},
	"keywords": [
		"nmp",
		"mcp",
		"wasm",
		"ai",
		"agent",
		"grpc",
		"p2p"
	],
	"author": "Nekzus",
	"license": "MIT",
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^25.3.1",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"@grpc/grpc-js": "^1.14.3",
		"@grpc/proto-loader": "^0.8.0",
		"@libp2p/identify": "^4.0.10",
		"@libp2p/kad-dht": "^16.1.3",
		"@libp2p/mplex": "^12.0.11",
		"@libp2p/noise": "^1.0.1",
		"@libp2p/websockets": "^10.1.3",
		"libp2p": "^3.1.3"
	}
}