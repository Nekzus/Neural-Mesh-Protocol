{
	"include": ["./"],
	"exclude": ["node_modules", "dist"],
	"compilerOptions": {
		"target": "es2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"paths": {
			"*": ["./*"],
			"@nekzus/neural-mesh": ["./node_modules/@nekzus/neural-mesh/src/index.ts"]
		}
	}
}
