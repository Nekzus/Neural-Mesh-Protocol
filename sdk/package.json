{
	"name": "@neural-mesh/sdk",
	"version": "1.0.0-alpha.1",
	"description": "SDK oficial para Neural Mesh Protocol (NMP). Despliega Logic-on-Origin con WebAssembly a velocidad gRPC y compatibilidad MCP bidireccional.",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"build": "tsc",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "biome lint .",
		"format": "biome format --write .",
		"check": "biome check ."
	},
	"keywords": [
		"nmp",
		"mcp",
		"wasm",
		"ai",
		"agent",
		"grpc",
		"p2p"
	],
	"author": "Nekzus",
	"license": "MIT",
	"type": "module",
	"devDependencies": {
		"@biomejs/biome": "^2.4.4",
		"@types/node": "^25.3.1",
		"typescript": "^5.9.3",
		"vitest": "^4.0.18",
		"zod": "^4.3.6"
	}
}
