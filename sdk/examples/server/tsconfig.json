{
    "include": [
        "./"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
    "compilerOptions": {
        "target": "es2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "paths": {
            "*": [
                "./*"
            ],
            "@neural-mesh/sdk": [
                "./node_modules/@neural-mesh/sdk/src/index.ts"
            ]
        }
    }
}