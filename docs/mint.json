        "dark": "/logo/dark.svg",
        "light": "/logo/light.svg"
    },
    "favicon": "/favicon.svg",
    "colors": {
        "primary": "#09090b",
        "light": "#FAFAFA",
        "dark": "#09090b"
    },
    "navbar": {
